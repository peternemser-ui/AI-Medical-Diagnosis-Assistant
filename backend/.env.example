# AI Medical Diagnosis Assistant — Backend Configuration
# =====================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.

# === AI PROVIDER KEYS ===
# Anthropic (recommended — powers the multi-agent system)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# OpenAI (legacy fallback)
# OPENAI_API_KEY=sk-your-api-key-here

# === SECURITY SECRETS ===
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# === AZURE SPEECH (optional) ===
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=centralus

# === CORS ===
# Comma-separated list of allowed origins. NEVER use * in production.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# === HTTPS ===
# Set to "true" in production to enable HSTS header
ENFORCE_HTTPS=false
